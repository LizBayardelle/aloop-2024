<header class="container text-center py-3">
  <h1 class="display-5 fw-bold mb-2">Customer Images</h1>
  <p class="lead text-muted mb-2">See real builds from hundreds of our happy customers</p>
  <button type="button" class="btn btn-red px-4 py-2 mb-2" data-bs-toggle="modal" data-bs-target="#newPhotoModal">
    <i class="fas fa-camera me-2"></i> Submit Your Photo
  </button>

  <!-- Modal -->
  <div class="modal fade" id="newPhotoModal" tabindex="-1" aria-labelledby="newPhotoModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <%= render partial: "photos/modal_innards", locals: { photo: Photo.new } %>
      </div>
    </div>
  </div>
</header>


<% if current_user && current_user.admin && @unapproved_photos&.any? %>
  <section class="bg-blue py-5">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white mb-0">
          <i class="fas fa-clock me-2"></i> Photos Pending Approval
        </h3>
        <span class="badge bg-white text-dark fs-6 px-3 py-2"><%= @unapproved_photos.count %> pending</span>
      </div>
      <div class="row g-4">
        <% @unapproved_photos.each do |photo| %>
          <% next unless photo.image.attached? %>
          <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="photo-card photo-thumbnail"
                 data-bs-toggle="modal"
                 data-bs-target="#photoModal"
                 data-photo-id="<%= photo.id %>"
                 data-photo-url="<%= url_for(photo.display_image) %>"
                 data-photo-comments="<%= photo.comments %>"
                 data-photo-approved="<%= photo.approved %>"
                 data-approve-url="<%= approve_photo_path(photo) %>"
                 data-delete-url="<%= photo_path(photo) %>">
              <div class="photo-card-inner">
                <img src="<%= url_for(photo.thumbnail) %>" alt="Pending customer photo" loading="lazy">
                <div class="photo-overlay">
                  <i class="fas fa-search-plus"></i>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>



<section class="container pt-3 pb-5">
   <div class="portfolio-menu mb-3">
      <div class="photo-filter-bar">
        <button id="targetall" class="filter-btn active" data-filter="*">
          <i class="fas fa-th me-2"></i>
          <span>All</span>
        </button>
        <button id="target-kit1" class="filter-btn" data-filter="kit1">
          <i class="fas fa-motorcycle me-2"></i>
          <span>XR250/XR400</span>
        </button>
        <button id="target-kit2" class="filter-btn" data-filter="kit2">
          <i class="fas fa-motorcycle me-2"></i>
          <span>XR600</span>
        </button>
        <button id="target-kit3" class="filter-btn" data-filter="kit3">
          <i class="fas fa-motorcycle me-2"></i>
          <span>SM/XR650L</span>
        </button>
      </div>
   </div>

  <div class="row g-4 mb-5">
    <% @approved_photos.each do |photo| %>
      <% next unless photo.image.attached? %>
      <div class="portfolio-item item <%= photo.kit %> col-xl-3 col-lg-4 col-md-6">
        <div class="photo-card photo-thumbnail"
             data-bs-toggle="modal"
             data-bs-target="#photoModal"
             data-photo-id="<%= photo.id %>"
             data-photo-url="<%= url_for(photo.display_image) %>"
             data-photo-comments="<%= photo.comments %>"
             data-photo-kit="<%= photo.kit %>"
             data-photo-approved="<%= photo.approved %>"
             data-approve-url="<%= approve_photo_path(photo) %>"
             data-delete-url="<%= photo_path(photo) %>">
          <div class="photo-card-inner">
            <img src="<%= url_for(photo.thumbnail) %>" alt="Customer <%= photo.kit %> build" loading="lazy">
            <div class="photo-overlay">
              <i class="fas fa-search-plus"></i>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

</section>

<!-- Photo Lightbox Modal -->
<div class="modal fade" id="photoModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered photo-lightbox-dialog">
    <div class="modal-content photo-lightbox-content">
      <button type="button" class="btn-close btn-close-white photo-lightbox-close" data-bs-dismiss="modal" aria-label="Close"></button>

      <div class="modal-body p-0">
        <div class="photo-lightbox-layout">
          <!-- Image -->
          <div class="photo-lightbox-img-wrap">
            <img id="modalPhotoImage" class="photo-lightbox-img" src="" alt="Customer photo">
          </div>

          <!-- Sidebar -->
          <div class="photo-lightbox-sidebar">
            <div class="photo-lightbox-sidebar-inner">
              <!-- Kit Badge -->
              <div id="modalKitBadge" class="photo-lightbox-kit">
                <i class="fas fa-motorcycle me-1"></i>
                <span id="modalKitLabel"></span>
              </div>

              <!-- Comments -->
              <div class="photo-lightbox-comments-wrap">
                <h6 class="photo-lightbox-section-title">About This Build</h6>
                <p id="modalPhotoComments" class="photo-lightbox-comments"></p>
              </div>

              <!-- CTA -->
              <div class="photo-lightbox-cta">
                <p class="mb-2" style="font-size: 0.82rem; color: #888;">Have a build to share?</p>
                <button type="button" class="btn btn-red w-100" data-bs-toggle="modal" data-bs-target="#newPhotoModal" onclick="bootstrap.Modal.getInstance(document.getElementById('photoModal')).hide();">
                  <i class="fas fa-camera me-2"></i>Submit Your Photo
                </button>
              </div>
            </div>

            <% if current_user && current_user.admin %>
              <div id="modalPhotoActions" class="photo-lightbox-admin">
                <h6 class="photo-lightbox-section-title">Admin</h6>
                <div class="d-flex gap-2">
                  <a id="modalApproveBtn" href="#" class="btn btn-sm btn-outline-success flex-grow-1" data-method="post" style="display: none;">
                    <i class="fas fa-check me-1"></i>Approve
                  </a>
                  <form id="modalDeleteForm" method="post" class="flex-grow-1" style="display: inline;">
                    <input type="hidden" name="_method" value="delete">
                    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100" onclick="return confirm('Delete this photo?');">
                      <i class="fas fa-trash me-1"></i>Delete
                    </button>
                  </form>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script defer>
  document.addEventListener('DOMContentLoaded', function() {
    var kitLabels = { kit1: 'XR250 / XR400', kit2: 'XR600', kit3: 'SuperMotard & XR650L' };

    // Filter functionality
    var filterButtons = document.querySelectorAll('.filter-btn');
    filterButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        filterButtons.forEach(function(btn) { btn.classList.remove('active'); });
        this.classList.add('active');
        var filter = this.dataset.filter;
        var items = document.querySelectorAll('.portfolio-item');
        if (filter === '*') {
          items.forEach(function(item) { item.style.display = ''; });
        } else {
          items.forEach(function(item) {
            item.style.display = item.classList.contains(filter) ? '' : 'none';
          });
        }
      });
    });

    // Photo modal population
    document.querySelectorAll('.photo-thumbnail').forEach(function(thumbnail) {
      thumbnail.addEventListener('click', function() {
        var photoUrl = this.dataset.photoUrl;
        var comments = this.dataset.photoComments;
        var kit = this.dataset.photoKit;
        var approved = this.dataset.photoApproved === 'true';
        var approveUrl = this.dataset.approveUrl;
        var deleteUrl = this.dataset.deleteUrl;

        document.getElementById('modalPhotoImage').src = photoUrl;

        // Kit badge
        var kitBadge = document.getElementById('modalKitBadge');
        var kitLabel = document.getElementById('modalKitLabel');
        if (kit && kitLabels[kit]) {
          kitLabel.textContent = kitLabels[kit];
          kitBadge.style.display = 'inline-flex';
        } else {
          kitBadge.style.display = 'none';
        }

        // Comments
        var commentsEl = document.getElementById('modalPhotoComments');
        if (comments && comments.trim() !== '') {
          commentsEl.textContent = comments;
          commentsEl.style.color = '#ddd';
          commentsEl.style.fontStyle = 'normal';
        } else {
          commentsEl.textContent = 'No description provided';
          commentsEl.style.color = '#666';
          commentsEl.style.fontStyle = 'italic';
        }

        // Admin actions
        var approveBtn = document.getElementById('modalApproveBtn');
        var deleteForm = document.getElementById('modalDeleteForm');
        if (approveBtn && deleteForm) {
          if (!approved) {
            approveBtn.href = approveUrl;
            approveBtn.style.display = 'inline-block';
          } else {
            approveBtn.style.display = 'none';
          }
          deleteForm.action = deleteUrl;
        }
      });
    });
  });
</script>

<style>
  /* Lightbox Dialog */
  .photo-lightbox-dialog { max-width: 1000px; }
  .photo-lightbox-content {
    background: #1a1a2e;
    border: none;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 25px 60px rgba(0,0,0,0.5);
  }
  .photo-lightbox-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    opacity: 0.6;
    filter: none;
  }
  .photo-lightbox-close:hover { opacity: 1; }

  /* Layout */
  .photo-lightbox-layout {
    display: flex;
    min-height: 500px;
  }

  /* Image */
  .photo-lightbox-img-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #111;
    min-height: 400px;
  }
  .photo-lightbox-img {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
  }

  /* Sidebar */
  .photo-lightbox-sidebar {
    width: 280px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.75rem 1.5rem;
    background: #1a1a2e;
  }
  .photo-lightbox-sidebar-inner { flex: 1; }

  .photo-lightbox-section-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #555;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  /* Kit Badge */
  .photo-lightbox-kit {
    display: inline-flex;
    align-items: center;
    background: rgba(46,61,153,0.2);
    color: #7b8cff;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }

  /* Comments */
  .photo-lightbox-comments-wrap { margin-bottom: 2rem; }
  .photo-lightbox-comments {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #ddd;
    margin: 0;
  }

  /* CTA */
  .photo-lightbox-cta {
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  /* Admin */
  .photo-lightbox-admin {
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  /* Filter Bar */
  .photo-filter-bar {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Responsive: stack on mobile */
  @media (max-width: 767px) {
    .photo-lightbox-layout { flex-direction: column; }
    .photo-lightbox-sidebar { width: 100%; }
    .photo-lightbox-img-wrap { min-height: 250px; }

    /* Compact filter bar: horizontal scroll, no wrap */
    .photo-filter-bar {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      gap: 0.5rem;
      padding-bottom: 4px;
      scrollbar-width: none;
    }
    .photo-filter-bar::-webkit-scrollbar { display: none; }
    .filter-btn {
      padding: 8px 14px;
      font-size: 0.82rem;
      white-space: nowrap;
      flex-shrink: 0;
    }
  }
</style>









